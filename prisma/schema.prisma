generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  name         String
  role         String   @default("MANAGER")
  // WAITER role: linked to a restaurant (null for owners/admins)
  staffRestaurantId String?
  staffRestaurant   Restaurant? @relation("RestaurantStaff", fields: [staffRestaurantId], references: [id], onDelete: Cascade)
  // WAITER: JSON array of table numbers, e.g. ["1","2","3"]. Empty array = all tables.
  assignedTables String @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant?
}

model Restaurant {
  id           String @id @default(cuid())
  name         String
  slug         String @unique
  description  String?
  logo         String?
  coverImage   String?
  address      String?
  phone        String?
  email        String?
  website      String?
  cuisine      String @default("[]")
  status       String @default("PENDING")
  templateId   String @default("modern")
  primaryColor String @default("#f97316")
  menuPdfUrl   String?
  menuPdfName  String?
  primaryMenu   String  @default("dynamic")
  openingHours  String  @default("{}")
  announcement  String?
  socialLinks   String  @default("{}")
  wifiPassword  String?
  bookingUrl    String?
  currency      String  @default("€")
  promotions    String  @default("[]")  // JSON array of promotion objects
  customTags    String  @default("[]")  // JSON array of manager-defined tag strings
  ownerId       String  @unique
  owner        User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  categories   MenuCategory[]
  dailyMenus   DailyMenu[]
  feedbacks    Feedback[]
  scans        MenuScan[]
  waiterCalls  WaiterCall[]
  searchTerms  SearchTerm[]
  staff        User[]         @relation("RestaurantStaff")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MenuCategory {
  id           String     @id @default(cuid())
  name         String
  description  String?
  icon         String?
  order        Int        @default(0)
  schedule     String?    // JSON: { enabled, days[], startTime, endTime }
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items        MenuItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MenuItem {
  id          String       @id @default(cuid())
  name        String
  description String?
  price       Float
  image       String?
  allergens   String       @default("[]")
  tags        String       @default("[]")
  prepTime    Int?
  isAvailable Boolean      @default(true)
  isFeatured  Boolean      @default(false)
  order       Int          @default(0)
  categoryId  String
  category    MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  feedbacks   Feedback[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DailyMenu {
  id           String     @id @default(cuid())
  date         String
  title        String?
  description  String?
  items        String     @default("[]")
  isActive     Boolean    @default(true)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Feedback {
  id           String     @id @default(cuid())
  rating       Int
  comment      String?
  customerName String?
  menuItemId   String?
  menuItem     MenuItem?  @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model MenuScan {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  deviceType   String?
  userAgent    String?

  createdAt DateTime @default(now())
}

model WaiterCall {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tableNumber  String?
  message      String?
  status       String     @default("pending")   // pending | resolved

  createdAt DateTime @default(now())
}

model SearchTerm {
  id             String     @id @default(cuid())
  restaurantId   String
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  term           String
  count          Int        @default(1)
  lastSearchedAt DateTime   @default(now())

  @@unique([restaurantId, term])
}

model WaiterPushSub {
  id           String   @id
  restaurantId String
  userId       String
  endpoint     String   @unique
  p256dh       String
  auth         String
  createdAt    DateTime @default(now())
}
