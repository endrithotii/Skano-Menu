generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  name         String
  role         String   @default("MANAGER")
  // WAITER role: linked to a restaurant (null for owners/admins)
  staffRestaurantId String?
  staffRestaurant   Restaurant? @relation("RestaurantStaff", fields: [staffRestaurantId], references: [id], onDelete: Cascade)
  // WAITER: JSON array of table numbers, e.g. ["1","2","3"]. Empty array = all tables.
  assignedTables String @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant?
}

model Restaurant {
  id           String @id @default(cuid())
  name         String
  slug         String @unique
  description  String?
  logo         String?
  coverImage   String?
  address      String?
  phone        String?
  email        String?
  website      String?
  cuisine      String @default("[]")
  status       String @default("PENDING")
  templateId   String @default("modern")
  primaryColor String @default("#f97316")
  menuPdfUrl   String?
  menuPdfName  String?
  primaryMenu   String  @default("dynamic")
  openingHours  String  @default("{}")
  announcement  String?
  socialLinks   String  @default("{}")
  wifiPassword  String?
  bookingUrl    String?
  currency      String  @default("€")
  promotions    String  @default("[]")  // JSON array of promotion objects
  customTags    String  @default("[]")  // JSON array of manager-defined tag strings
  themeConfig       String  @default("{}")   // JSON: font, colors, element toggles, card style
  metaTitle         String?                  // SEO title override
  metaDescription   String?                  // SEO description
  googleAnalyticsId String?                  // GA tracking ID
  googlePlaceId     String?                  // Google Places ID for rating display
  loyaltyEnabled    Boolean @default(false)
  loyaltyStamps     Int     @default(10)     // stamps to earn reward
  loyaltyReward     String  @default("Free item")
  tableMap          String  @default("[]")   // JSON array of table objects {id,x,y,w,h,shape,seats,section}
  sections          String  @default("[]")   // JSON array of section names
  flashSales        String  @default("[]")   // deprecated - use FlashSale table
  planTier          String  @default("free") // free | starter | pro | enterprise
  isVerified        Boolean @default(false)
  healthScore       Int?                     // admin-assigned 0-100
  notes             String?                  // admin internal notes
  ownerId       String  @unique
  owner        User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  categories   MenuCategory[]
  dailyMenus   DailyMenu[]
  feedbacks    Feedback[]
  scans        MenuScan[]
  waiterCalls  WaiterCall[]
  searchTerms  SearchTerm[]
  staff        User[]         @relation("RestaurantStaff")
  managers     RestaurantManager[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MenuCategory {
  id           String     @id @default(cuid())
  name         String
  description  String?
  icon         String?
  order        Int        @default(0)
  schedule     String?    // JSON: { enabled, days[], startTime, endTime }
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items        MenuItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MenuItem {
  id          String       @id @default(cuid())
  name        String
  description String?
  price       Float
  image       String?
  images      String       @default("[]")   // JSON array of extra image URLs
  allergens   String       @default("[]")
  tags        String       @default("[]")
  prepTime    Int?
  isAvailable Boolean      @default(true)
  isFeatured  Boolean      @default(false)
  isHidden    Boolean      @default(false)  // hidden from customers, visible in admin
  order       Int          @default(0)
  spiceLevel  Int?                           // 0-5
  calories    Int?
  protein     Float?
  carbs       Float?
  fat         Float?
  costPrice   Float?                         // food cost for margin calc
  chefNote    String?                        // chef's story / note
  variants    String       @default("[]")   // JSON array of {name, options:[{label,priceDelta}]}
  viewCount   Int          @default(0)      // how many times this item was viewed
  categoryId  String
  category    MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  feedbacks   Feedback[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MenuSnapshot {
  id           String   @id @default(cuid())
  restaurantId String
  label        String                        // e.g. "Before big update"
  data         String                        // JSON snapshot of full menu
  createdAt    DateTime @default(now())
}

model FlashSale {
  id           String   @id @default(cuid())
  restaurantId String
  title        String
  discountType String   @default("percent") // percent | fixed
  discountValue Float
  itemIds      String   @default("[]")      // empty = whole menu
  startsAt     DateTime
  endsAt       DateTime
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model LoyaltyCard {
  id           String   @id @default(cuid())
  restaurantId String
  deviceId     String                        // fingerprint / device identifier
  stamps       Int      @default(0)
  totalStamps  Int      @default(10)         // stamps needed for reward
  rewardLabel  String   @default("Free item")
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  @@unique([restaurantId, deviceId])
}

model FeedbackReply {
  id         String   @id @default(cuid())
  feedbackId String   @unique
  reply      String
  createdAt  DateTime @default(now())
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String
  restaurantId String?
  action       String
  entity       String
  entityId     String?
  detail       String?
  createdAt    DateTime @default(now())
}

model OperatingException {
  id           String   @id @default(cuid())
  restaurantId String
  date         String   // YYYY-MM-DD
  label        String   // e.g. "Christmas Day"
  closed       Boolean  @default(true)
  openTime     String?
  closeTime    String?
  createdAt    DateTime @default(now())
}

// Multi-location: a manager can be granted access to restaurants they don't own
model RestaurantManager {
  id           String     @id @default(cuid())
  userId       String
  restaurantId String
  role         String     @default("manager")  // manager | viewer
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  @@unique([userId, restaurantId])
}

model DailyMenu {
  id           String     @id @default(cuid())
  date         String
  title        String?
  description  String?
  items        String     @default("[]")
  isActive     Boolean    @default(true)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Feedback {
  id           String     @id @default(cuid())
  rating       Int
  comment      String?
  customerName String?
  menuItemId   String?
  menuItem     MenuItem?  @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model MenuScan {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  deviceType   String?
  userAgent    String?

  createdAt DateTime @default(now())
}

model WaiterCall {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tableNumber  String?
  message      String?
  status       String     @default("pending")   // pending | resolved

  createdAt DateTime @default(now())
}

model SearchTerm {
  id             String     @id @default(cuid())
  restaurantId   String
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  term           String
  count          Int        @default(1)
  lastSearchedAt DateTime   @default(now())

  @@unique([restaurantId, term])
}

model WaiterPushSub {
  id           String   @id
  restaurantId String
  userId       String
  endpoint     String   @unique
  p256dh       String
  auth         String
  createdAt    DateTime @default(now())
}
